{
  "restore_on_startup": "last_workspace",
  "soft_wrap": "editor_width",
  "project_panel": {
    "dock": "left"
  },
  "session": {
    "trust_all_worktrees": true
  },
  "agent": {
    "play_sound_when_agent_done": "never",
    "enable_feedback": false,
    "default_model": {
      "provider": "zed.dev",
      "model": "claude-haiku-4-5",
      "enable_thinking": false
    },
    "favorite_models": [],
    "model_parameters": []
  },
  "languages": {
    "YAML": {
      "format_on_save": "off"
    }
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000
    }
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "base_keymap": "Cursor",
  "icon_theme": {
    "mode": "system",
    "light": "Zed (Default)",
    "dark": "Zed (Default)"
  },
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark"
  }
}
