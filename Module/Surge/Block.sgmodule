#!name=系统更新拦截器
#!desc=屏蔽Apple系统更新请求，避免出现红点
#!category=Hub
#!date=2026-03-16 15:15:00

[Rule]
# iOS&macOS 系统更新
DOMAIN-SUFFIX,gdmf.apple.com,REJECT,extended-matching,pre-matching

# macOS 系统更新
DOMAIN-SUFFIX,swdist.apple.com,REJECT,extended-matching,pre-matching
DOMAIN-SUFFIX,swscan.apple.com,REJECT,extended-matching,pre-matching