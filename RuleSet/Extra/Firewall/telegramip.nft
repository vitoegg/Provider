#!/usr/sbin/nft -f

table ip telegramip
delete table ip telegramip

table ip telegramip {
    set bad_ipv4 {
        type ipv4_addr
        elements = {
            91.108.56.100,
            91.108.56.101,
            91.108.56.104,
            91.108.56.107,
            91.108.56.120,
            91.108.56.125,
            91.108.56.126,
            91.108.56.128,
            91.108.56.156
        }
    }

    chain output {
        type nat hook output priority -100; policy accept;
        ip daddr @bad_ipv4 counter \
            dnat to numgen random mod 2 map { 0 : 91.108.56.147, 1 : 91.108.56.201 }
    }
}
